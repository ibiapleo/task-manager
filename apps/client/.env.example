# NestJS API base URL (see apps/api/src/main.ts - defaults to port 3001)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase project - the frontend owns the entire auth lifecycle (sign up,
# sign in, session refresh, sign out). Only the resulting access token is
# ever sent to the API, as a Bearer header.
# Same value as SUPABASE_URL in the root .env.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Anon/publishable key from Supabase Dashboard -> Settings -> API.
# This key is safe to expose client-side (that's what "anon"/"publishable" means).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
