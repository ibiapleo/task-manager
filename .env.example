# Base supabase URL
SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable/anon key for public auth.signUp — same as NEXT_PUBLIC_SUPABASE_ANON_KEY
# (sb_publishable_… or legacy JWT eyJ…). Do not use the secret/service_role key.
SUPABASE_ANON_KEY=your-anon-key-here

# Prisma / Postgres (Supabase)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma Migrate
DATABASE_DIRECT_URL="postgresql://user:password@host:5432/postgres"

API_PORT=3001
CLIENT_PORT=3000
FRONTEND_URL=http://localhost:3000

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
